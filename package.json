  "type": "module",
  "scripts": {
    "start": "node app.js",
    "typeorm": "typeorm",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- -d src/config/dbconnect.js migration:generate src/migrations",
    "migration:run": "npm run typeorm -- -d src/config/dbconnect.js migration:run",
    "migration:revert": "npm run typeorm -- -d src/config/dbconnect.js migration:revert",
    "migration:show": "npm run typeorm -- -d src/config/dbconnect.js migration:show"
  },
